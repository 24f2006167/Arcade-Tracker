# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Settings -> API -> service_role key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AdSense Monetization
# Your publisher ID: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1234567890123456
NEXT_PUBLIC_ADSENSE_SLOT_HOME=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD=1234567890
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD=1234567890
